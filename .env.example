# Copy to .env and fill in your Dash0 ingress + auth token.
# Docker Compose picks .env up automatically from the project root.
#
# Before the first `docker compose up`, download the OpenTelemetry Java Agent
# which is bind-mounted into the Kafka container:
#
#   curl -sSL -o agent/opentelemetry-javaagent.jar \
#     https://github.com/open-telemetry/opentelemetry-java-instrumentation/releases/latest/download/opentelemetry-javaagent.jar

# Region-specific OTLP gRPC endpoint, e.g. ingress.eu-west-1.aws.dash0.com:4317
DASH0_OTLP_ENDPOINT=ingress.eu-west-1.aws.dash0.com:4317

# Bearer token from the Dash0 UI (Settings → Auth Tokens).
DASH0_AUTH_TOKEN=replace-me

# Optional. If unset the collector uses the "default" dataset.
DASH0_DATASET=default
